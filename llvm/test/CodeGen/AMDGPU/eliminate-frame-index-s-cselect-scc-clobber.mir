# NOTE: Assertions have been autogenerated by utils/update_mir_test_checks.py
# RUN: llc -mtriple=amdgcn-amd-amdhsa -mcpu=gfx942 -verify-machineinstrs -run-pass=prologepilog %s -o - | FileCheck -check-prefix=FLATSCRW64 %s
# RUN: llc -mtriple=amdgcn-amd-amdhsa -mcpu=gfx1100 -verify-machineinstrs -run-pass=prologepilog %s -o - | FileCheck -check-prefix=FLATSCRW32 %s

---
# S_CSELECT_B32 with a frame index true-operand, preceded immediately by
# S_AND_B64 which produces SCC. The frame index has a non-zero offset so
# the ADDC path applies. Verify ADDC+BITCMP1+BITSET0 is generated.
name: s_cselect_b32_fi_after_scc_producer
tracksRegLiveness: true
stack:
  - { id: 0, size: 64, alignment: 4 }
  - { id: 1, size: 4, alignment: 4 }
machineFunctionInfo:
  scratchRSrcReg:  '$sgpr0_sgpr1_sgpr2_sgpr3'
  frameOffsetReg:  '$sgpr33'
  stackPtrOffsetReg: '$sgpr32'
body:             |
  bb.0:
    liveins: $sgpr4, $sgpr5, $sgpr6

    ; S_AND_B64 produces SCC. The regscavenger backward scan from S_CSELECT_B32
    ; will call stepBackward on S_AND_B64, removing SCC from liveness. Without
    ; the fix, RS->isRegUsed(SCC) returns false -> NeedSaveSCC=false -> plain
    ; S_ADD_I32 is inserted before S_CSELECT_B32 -> SCC clobbered -> wrong result.
    ; FLATSCRW64-LABEL: name: s_cselect_b32_fi_after_scc_producer
    ; FLATSCRW64: liveins: $sgpr4, $sgpr5, $sgpr6
    ; FLATSCRW64-NEXT: {{  $}}
    ; FLATSCRW64-NEXT: renamable $sgpr4_sgpr5 = S_AND_B64 killed renamable $sgpr4_sgpr5, $exec, implicit-def $scc
    ; FLATSCRW64-NEXT: $sgpr5 = S_ADDC_U32 $sgpr32, 64, implicit-def $scc, implicit $scc
    ; FLATSCRW64-NEXT: S_BITCMP1_B32 $sgpr5, 0, implicit-def $scc
    ; FLATSCRW64-NEXT: $sgpr5 = S_BITSET0_B32 0, $sgpr5
    ; FLATSCRW64-NEXT: renamable $sgpr4 = S_CSELECT_B32 killed $sgpr5, $sgpr6, implicit $scc
    ; FLATSCRW64-NEXT: SI_RETURN implicit $sgpr4
    ;
    ; FLATSCRW32-LABEL: name: s_cselect_b32_fi_after_scc_producer
    ; FLATSCRW32: liveins: $sgpr4, $sgpr5, $sgpr6
    ; FLATSCRW32-NEXT: {{  $}}
    ; FLATSCRW32-NEXT: renamable $sgpr4_sgpr5 = S_AND_B64 killed renamable $sgpr4_sgpr5, $exec, implicit-def $scc
    ; FLATSCRW32-NEXT: $sgpr5 = S_ADDC_U32 $sgpr32, 64, implicit-def $scc, implicit $scc
    ; FLATSCRW32-NEXT: S_BITCMP1_B32 $sgpr5, 0, implicit-def $scc
    ; FLATSCRW32-NEXT: $sgpr5 = S_BITSET0_B32 0, $sgpr5
    ; FLATSCRW32-NEXT: renamable $sgpr4 = S_CSELECT_B32 killed $sgpr5, $sgpr6, implicit $scc
    ; FLATSCRW32-NEXT: SI_RETURN implicit $sgpr4
    renamable $sgpr4_sgpr5 = S_AND_B64 killed renamable $sgpr4_sgpr5, $exec, implicit-def $scc
    ; %stack.1 is at offset 64 from frame base (non-zero), so eliminateFrameIndex
    ; cannot use the trivial FrameReg-only path.  Verify it uses ADDC+BITCMP1+BITSET0.
    renamable $sgpr4 = S_CSELECT_B32 %stack.1, $sgpr6, implicit $scc
    SI_RETURN implicit $sgpr4

...
